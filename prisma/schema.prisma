generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Question {
  id            String   @id @default(cuid())
  text          String   // Transcribed text (English/Hindi/Hinglish)
  originalVoice String?  // URL to the stored audio file (S3/Supabase Storage)
  studentEmail  String   
  isVerified    Boolean  @default(false)
  otp           String?  
  status        Status   @default(PENDING)
  createdAt     DateTime @default(now())
  
  answer        Answer?
}

// Update your Answer model
model Answer {
  id         String   @id @default(cuid())
  text       String   
  // We use Unsupported for the vector type in Prisma
  embedding  Unsupported("vector(768)")? 
  questionId String   @unique
  question   Question @relation(fields: [questionId], references: [id])
  createdAt  DateTime @default(now())
}

enum Status {
  PENDING
  ANSWERED
  IGNORE 
}